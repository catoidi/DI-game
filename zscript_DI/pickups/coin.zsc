//zscript_DI/pickups/coin.zsc

Class DI_Coin : DI_CashPickup
{
	Default
	{
		DI_CashPickup.DespawnColor "ffe31e";
	}

	States
	{
		Spawn:
			COIN A 0 NoDelay A_Jump(256, "Spinner");
			Stop;
	}
}

Class DI_Money : DI_CashPickup
{
	Default 
	{
		Inventory.Amount 3;
		DI_CashPickup.DespawnColor "529c54";
	}
	
	States
	{
		Spawn:
			COIN B 0 NoDelay A_Jump(256, "Spinner");
			Stop;
	}
}

Class DI_Gem : DI_CashPickup
{
	Default 
	{
		Inventory.Amount 5;
		DI_CashPickup.DespawnColor "94c5ea";
	}
	
	States
	{
		Spawn:
			COIN C 0 NoDelay A_Jump(256, "Spinner");
			Stop;
	}
}